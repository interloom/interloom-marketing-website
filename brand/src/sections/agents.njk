<style>
  /* ── Grid ── */
  .agents-board {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    padding-bottom: 2rem;
  }
  @media (min-width: 640px) {
    .agents-board {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 3rem 2.5rem;
    }
  }

  /* ── Coin sizing and interaction ── */
  .agent-coin {
    --coin-size: 5.5rem;
    position: relative;
    width: var(--coin-size);
    height: var(--coin-size);
    cursor: default; /* Changed from pointer since no click action anymore */
    border-radius: 50%;
    /* 3D lift effect on hover */
    transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
    transform-style: preserve-3d;
  }
  
  @media (min-width: 768px) {
    .agent-coin {
      --coin-size: 6.5rem;
    }
  }

  .agent-coin:hover {
    transform: translateY(-4px) scale(1.02) rotateX(5deg) rotateY(-5deg);
  }

  /* ── Coin face (The body of the coin) ── */
  .coin-face {
    position: relative;
    width: 100%;
    height: 100%;
    border-radius: 50%;
    overflow: hidden;
    
    /* Conic gradient for an angular, metallic coin-like reflection
       Stops are organically offset (not equal) for a more natural metallic reflection */
    box-shadow: 
      inset 1px 1px 1px rgba(255, 255, 255, 0.3),
      inset -1px -1px 2px rgba(0, 0, 0, 0.8),
      inset 0 0 0 3px rgba(255, 255, 255, 0.1),
      inset 4px 4px 5px rgba(0, 0, 0, 0.5),
      inset -3px -3px 4px rgba(255, 255, 255, 0.08),
      0 8px 16px -4px rgba(0, 0, 0, 0.35);
    background:
      conic-gradient(
        from 115deg at 50% 50%,
        rgba(255, 255, 255, 0.2) 0%,
        rgba(0, 0, 0, 0.2) 12%,
        rgba(255, 255, 255, 0.4) 26%,
        rgba(0, 0, 0, 0.3) 38%,
        rgba(255, 255, 255, 0.15) 62%,
        rgba(0, 0, 0, 0.3) 75%,
        rgba(255, 255, 255, 0.3) 93%,
        rgba(255, 255, 255, 0.2) 100%
      ),
      var(--agent-tint);
      
    transition: box-shadow 0.3s ease, background 0.3s ease;
  }

  /* ── Inner vignette for depth ── */
  .coin-face::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 50%;
    /* Keep a subtle edge burn to emphasize the rim */
    background: radial-gradient(circle at 50% 50%, transparent 50%, rgba(0,0,0,0.2) 100%);
    mix-blend-mode: multiply;
    pointer-events: none;
  }

  /* ── Specular highlight — flat metallic sheen ── */
  .coin-face::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 50%;
    /* A broad diagonal slash of light rather than a domed arc */
    background: linear-gradient(
      135deg,
      rgba(255, 255, 255, 0.6) 0%,
      rgba(255, 255, 255, 0.1) 30%,
      transparent 40%,
      transparent 60%,
      rgba(0, 0, 0, 0.1) 75%,
      rgba(0, 0, 0, 0.25) 100%
    );
    mix-blend-mode: overlay;
    pointer-events: none;
    opacity: 0.9;
    transition: opacity 0.3s ease, background 0.3s ease;
  }
  
  /* ── Interaction spec adjustments ── */
  .agent-coin:hover .coin-face::after {
    opacity: 1;
    background: linear-gradient(
      135deg,
      rgba(255, 255, 255, 0.6) 0%,
      rgba(255, 255, 255, 0.2) 30%,
      transparent 45%,
      transparent 55%,
      rgba(0, 0, 0, 0.15) 75%,
      rgba(0, 0, 0, 0.35) 100%
    );
  }

  /* ── Icon (Solid and legible) ── */
  .coin-icon {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 44%;
    height: 44%;
    transform: translate(-50%, -50%);
    color: white;
    filter: drop-shadow(0 2px 4px rgba(0, 0, 0, 0.25));
    pointer-events: none;
    z-index: 10;
  }
</style>

