<div class="max-w-4xl">
  <h1 class="font-serif text-3xl mb-2">Agents</h1>
  <p class="text-fg-3 text-sm mb-10">Premium coin avatars with tactile materials and engraved icons.</p>

  <div class="rounded-lg border border-line bg-surface-1 overflow-hidden">
    <div class="px-6 md:px-10 py-16 md:py-24">
      <p class="text-xl md:text-2xl text-fg-3 leading-snug tracking-tight max-w-3xl mb-16"><span class="text-fg-1">Meet the agents.</span> Every automation in Interloom is carried out by a named agent with a clear role, bounded authority, and a traceable history of every action it takes.</p>

      <div class="agents-board">
        {% for agent in agents %}
        <div class="flex items-center gap-5">

          {# ── Coin avatar ── #}
          <div
            class="agent-coin shrink-0"
            style="--agent-tint: var(--tint-{{ agent.tint }})"
            role="img"
            aria-label="{{ agent.name }} agent"
          >
            <div class="coin-face">
              <svg class="coin-icon" viewBox="0 0 256 256" aria-hidden="true">
                <path d="{{ agent.icon }}" fill="currentColor" />
              </svg>
            </div>
          </div>

          <div>
            <p class="text-fg-1 text-base font-medium">{{ agent.name }}</p>
            <p class="text-fg-3 text-sm leading-snug mt-1">{{ agent.role }}</p>
          </div>
        </div>
        {% endfor %}
      </div>
    </div>
  </div>
</div>

