<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }} | Interloom Brand</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Geist:wght@100..900&family=Geist+Mono:wght@100..900&family=Hedvig+Letters+Serif:opsz@12..24&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/main.css">
  <script>
    (function(){var s=localStorage.getItem('theme');var d=s?s==='dark':window.matchMedia('(prefers-color-scheme: dark)').matches;document.documentElement.classList.add(d?'dark':'light');})();
  </script>
</head>
<body class="bg-surface-2 text-fg-1 font-sans text-base leading-relaxed antialiased">
  <div class="scaffold" aria-hidden="true">
    <div class="gutter gutter-left"></div>
    <div class="gutter gutter-right"></div>
  </div>

  <header class="sticky top-0 z-50 bg-surface-2">
    <nav class="flex items-center justify-between px-4 py-3">
      <a href="/" class="font-serif text-lg no-underline text-fg-1">Interloom Brand</a>
      <div class="flex items-center gap-2 text-sm">
        <a href="/" class="{{ 'text-fg-1' if page.url == '/' else 'text-fg-3' }} px-2 py-0.5 rounded no-underline hover:text-fg-1 transition-colors" style="background:color-mix(in srgb,var(--color-fg-1) {{ '8%' if page.url == '/' else '0%' }},transparent)">Guide</a>
        <a href="/sections/hero/" class="{{ 'text-fg-1' if '/sections/' in page.url else 'text-fg-3' }} px-2 py-0.5 rounded no-underline hover:text-fg-1 transition-colors" style="background:color-mix(in srgb,var(--color-fg-1) {{ '8%' if '/sections/' in page.url else '0%' }},transparent)">Sections</a>
        <a href="/stories/" class="{{ 'text-fg-1' if '/stories/' in page.url else 'text-fg-3' }} px-2 py-0.5 rounded no-underline hover:text-fg-1 transition-colors" style="background:color-mix(in srgb,var(--color-fg-1) {{ '8%' if '/stories/' in page.url else '0%' }},transparent)">Stories</a>
      </div>
      <button id="theme-toggle" class="text-fg-3 hover:text-fg-1 text-sm transition-colors">Toggle theme</button>
    </nav>
  </header>

  <div class="shell grid grid-cols-1 md:grid-cols-[200px_1fr]">
    <aside class="border-b md:border-b-0 md:border-r border-line p-4 md:py-8 md:pr-0 md:pl-4">
      <nav class="md:sticky md:top-[49px]">
        {%- for section in brandNav.sections %}
        <div class="mb-6">
          <h4 class="text-[11px] font-mono font-medium uppercase tracking-wider text-fg-4 mb-2 px-2">{{ section.title }}</h4>
          <ul class="list-none p-0 m-0">
            {%- for item in section.items %}
            <li class="m-0">
              <a href="{{ item.url }}"
                 class="block py-1.5 px-2 text-sm rounded no-underline transition-colors
                        {% if page.url == item.url %}bg-surface-3 text-fg-1 font-medium{% else %}text-fg-3 hover:text-fg-1 hover:bg-surface-3/50{% endif %}">
                {{ item.title }}
              </a>
            </li>
            {%- endfor %}
            {%- if section.items.length == 0 %}
            <li class="m-0 px-2 text-sm text-fg-4 italic">Coming soon</li>
            {%- endif %}
          </ul>
        </div>
        {%- endfor %}
      </nav>
    </aside>

    <main class="min-w-0 px-6 md:px-10 py-8 md:py-12">
      {{ content | safe }}
    </main>
  </div>

  <script>
    document.getElementById('theme-toggle').addEventListener('click', () => {
      const html = document.documentElement;
      const isDark = html.classList.contains('dark');
      html.classList.remove('dark', 'light');
      html.classList.add(isDark ? 'light' : 'dark');
      localStorage.setItem('theme', isDark ? 'light' : 'dark');
    });
  </script>
</body>
</html>
