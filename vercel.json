{
  "buildCommand": "npm run build",
  "framework": null,
  "installCommand": "npm install",
  "rewrites": [
    {
      "source": "/xlog/static/:path(.*)",
      "destination": "https://eu-assets.i.posthog.com/static/:path"
    },
    {
      "source": "/xlog/:path(.*)",
      "destination": "https://eu.i.posthog.com/:path"
    }
  ]
}
