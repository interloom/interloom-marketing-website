{
  "name": "interloom-website",
  "version": "1.0.0",
  "scripts": {
    "dev:11ty": "eleventy --serve",
    "dev:css": "tailwindcss -i ./src/css/main.css -o ./_site/css/main.generated.css --watch=always",
    "start": "npm-run-all --parallel dev:*",
    "build:css": "tailwindcss -i ./src/css/main.css -o ./_site/css/main.generated.css --minify",
    "build:11ty": "eleventy",
    "build": "npm-run-all build:css build:11ty"
  },
  "devDependencies": {
    "@11ty/eleventy": "^2.0.1",
    "@tailwindcss/cli": "^4.2.1",
    "highlight.js": "^11.11.1",
    "markdown-it": "^13.0.2",
    "markdown-it-anchor": "^9.2.0",
    "npm-run-all": "^4.1.5",
    "tailwindcss": "^4.2.1"
  },
  "overrides": {
    "filelist": {
      "minimatch": "5.1.8"
    },
    "multimatch": {
      "minimatch": "3.1.4"
    },
    "maximatch": {
      "minimatch": "3.1.4"
    },
    "glob": {
      "minimatch": "3.1.4"
    },
    "npm-run-all": {
      "minimatch": "3.1.4"
    }
  }
}
